/* CycleHop – Français */

/* Welcome & onboarding */
"CycleHop" = "CycleHop";
"The open bike-share network." = "Le réseau de vélos en libre-service.";
"Get Started" = "C'est parti";
"Choose Your City" = "Choisissez votre ville";
"Continue" = "Continuer";
"This is a demo for the Apple Student Challenge. As the app is required to work offline, the data is an offline snapshot and location services are mocked. Online implementations are available on GitHub." = "Démo pour l'Apple Student Challenge. L'app fonctionne hors ligne avec des données figées et une localisation simulée. Les versions en ligne sont sur GitHub.";
"Don't see your city?" = "Votre ville n'apparaît pas ?";
"CycleHop is open-source - anyone can request a new city or help add one, no coding skills needed." = "CycleHop est open-source — tout le monde peut proposer une ville ou aider à en ajouter une, aucune compétence technique requise.";
"EggsLeggs/CycleHop on GitHub →" = "EggsLeggs/CycleHop sur GitHub →";

/* About / Mission */
"The Mission" = "Notre mission";
"Find bikes, wherever you go." = "Trouvez un vélo, où que vous soyez.";
"Find bikes and docks wherever you are. CycleHop connects to bike-share systems worldwide to get you moving - whether you're commuting, exploring, or running errands." = "Vélos et bornes à portée de main. CycleHop se connecte aux systèmes de vélos en libre-service du monde entier pour vous faire rouler — trajet, balade ou courses.";
"Bikes Across Your City" = "Des vélos partout en ville";
"See stations and availability on a map. Tap any dock to check bikes and free slots in real time, so you always know where to go." = "Visualisez les stations et les disponibilités sur la carte. Touchez une borne pour connaître en temps réel le nombre de vélos et de places libres.";
"Collect City Stamps" = "Collectionnez les tampons";
"Use bike share in a city and collect a stamp. Build your collection as you explore - each city you ride in leaves its mark." = "Utilisez un vélo en libre-service et gagnez un tampon. Chaque ville parcourue enrichit votre collection.";
"Open Protocol" = "Protocole ouvert";
"CycleHop is built on open standards. Anyone can contribute a new city or provider." = "CycleHop repose sur des standards ouverts. Tout le monde peut contribuer en ajoutant une ville ou un opérateur.";
"View on GitHub →" = "Voir sur GitHub →";

